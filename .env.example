# Docker Compose Environment Variables
# Copy this file to .env and fill in real values before running docker-compose up.
# NEVER commit .env to source control — it is listed in .gitignore.

# ── SQL Server ────────────────────────────────────────────────────────────────
# Minimum requirements enforced by SQL Server:
#   - At least 8 characters
#   - Contains uppercase, lowercase, digit, and special character
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long (256-bit minimum for HMAC-SHA256).
JWT_SECRET_KEY=
